# ─── Infrastructure (set these in Portainer) ───────────────────────────────

# Database — SQLite path inside Docker volume
DATABASE_URL="file:/app/data/habla.db"

# Auth — generate with: openssl rand -base64 32
# Also used as the encryption key for stored API keys, so keep it stable.
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="https://habla.yourdomain.com"

# Cloudflare tunnel token (cloudflared container)
CLOUDFLARE_TUNNEL_TOKEN=""

# ─── API Keys ───────────────────────────────────────────────────────────────
# Do NOT set these here for production.
# Instead, log in as admin and go to Admin → API Settings to enter and test
# each key through the UI. Keys are stored encrypted in the database.
#
# For local development only, you can set them here:
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
# TTS_PROVIDER="openai"          # "openai" or "elevenlabs"
# ELEVENLABS_API_KEY=""
# ELEVENLABS_VOICE_ID=""
