# Database (SQLite — path inside Docker volume)
DATABASE_URL="file:/app/data/habla.db"

# Auth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="https://habla.yourdomain.com"

# AI APIs
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# TTS provider: "openai" (default) or "elevenlabs"
TTS_PROVIDER="openai"

# ElevenLabs (only needed if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# Cloudflare tunnel token (from Zero Trust dashboard)
CLOUDFLARE_TUNNEL_TOKEN=""
